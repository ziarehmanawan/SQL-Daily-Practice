-- 1: Comparison Operators in SQL
-- matches age 30
SELECT * FROM employee2
WHERE age=30;

--matches all except 30
SELECT * FROM employee2
WHERE age!=30;

-- salary greather than 50000
SELECT * FROM employee2
WHERE salary>50000;

